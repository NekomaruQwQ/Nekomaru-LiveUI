{
    "extends": "@tsconfig/svelte/tsconfig.json",
    "compilerOptions": {
        "paths": {
            "@/*": ["./src/*"],
        },

        "lib": ["ESNext", "DOM"],
        "module": "ESNext",
        "moduleResolution": "bundler",

        "noEmit": true,
        "skipLibCheck": true,
        "noUnusedLocals": true,
        "noUnusedParameters": true,
        "noUncheckedIndexedAccess": true,
        "noImplicitOverride": true
    }
}
