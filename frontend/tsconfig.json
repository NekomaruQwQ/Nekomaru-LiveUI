{
    "compilerOptions": {
        "paths": {
            "@/*": ["./src/*"],
        },

        "target": "ESNext",
        "lib": [
            "ESNext",
            "DOM",
        ],

        "jsx": "react-jsx",
        "jsxImportSource": "react",

        "module": "preserve",
        "moduleResolution": "bundler",
        "noEmit": true,
        "stableTypeOrdering": true,
        "verbatimModuleSyntax": true,

        "skipLibCheck": true,
        "noUnusedLocals": true,
        "noUnusedParameters": true,
        "noUncheckedIndexedAccess": true,
        "noImplicitOverride": true
    }
}
